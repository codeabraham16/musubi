# Binarios compilados (anclados a la raíz para no excluir cmd/musubi/)
/musubi
/musubi.exe
/mcp-musubi
/mcp-musubi.exe
*.exe

# Base de datos local de Musubi (estado runtime, no se versiona)
*.db
*.db-shm
*.db-wal
.musubi/memory.db

# Config del workspace: es estado de LA MÁQUINA, no del proyecto. Suele llevar la IP del cerebro
# central y el nombre de la variable del token, así que versionarla filtra infraestructura privada a
# un repo público. La genera `musubi init`/`setup`, y `config.Load` aplica defaults si falta: nada la
# necesita versionada. Las claves están documentadas en .musubi/config.example.yaml (ese SÍ se versiona).
.musubi/config.yaml

# Snapshot del índice vectorial IVF: caché DERIVADO y reconstruible (centroides). Si falta o está
# corrupto, el engine cae al rebuild normal — nunca compromete correctness. No se versiona.
.musubi/memory.db.vindex

# Backups automáticos que hace `musubi doctor ... --apply` antes de reparar. Estado local de esta
# máquina (y copias enteras de la base): nunca se versionan.
.musubi/backups/

# Tablas de embeddings descargadas por `musubi embed pull` (puro dato, cientos de MB)
.musubi/embeddings/

# Artefactos de release (cross-compilados)
dist/

# Cobertura de tests
coverage.out
coverage.html

# Artefactos de editores / SO
.DS_Store
.idea/
.vscode/

# Artefactos de "musubi setup" corrido dentro de este repo (no versionar):
# .mcp.json, settings/hooks de Claude y todo lo que el propio setup/auto-discovery
# genera en .musubi/skills/ (skills .yaml + el sentinel .skills-generated).
/.mcp.json
/.claude/
.musubi/skills/

# Artefactos locales de SDD (musubi_sdd): specs/design/tasks de trabajo y sus plantillas.
# Son estado local del autor —pueden contener rutas/IPs de su entorno— y no se versionan; así
# un `git add -A` accidental nunca los sube (cierra el low "sdd sin gitignore" de la auditoría).
.musubi/sdd/
.musubi/templates/
